# === ノートPC最適化版設定ファイル（7-8GB RAM推奨）
# 使用方法: cp .env.laptop .env

# === Ollama設定（軽量・高速モデル優先）
OLLAMA_ENABLED=true
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_TIMEOUT=300
OLLAMA_NUM_PREDICT=1000

# === Ollama 細かい制御設定
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.95
OLLAMA_SEED=42

# === 深掘り分析設定
DEEP_ANALYSIS_ENABLED=true
DEEP_ANALYSIS_NUM_PREDICT=1500

# === AI高度分析機能フラグ
STRATEGIC_LP_ANALYSIS_ENABLED=true
FORECASTING_ENABLED=true
IMPACT_ANALYSIS_ENABLED=true

# === Vision AI設定（ノートPC: 軽量化版）
VISION_ANALYSIS_ENABLED=false
OLLAMA_VISION_MODEL=llava:7b
VISION_ANALYSIS_TIMEOUT=120
VISION_PROMPT_FILE=prompts/vision_lp_analysis.md

# === RAG設定（軽量）
RAG_ENABLED=true
CHROMA_PERSIST_DIRECTORY=./data/chroma
RAG_COLLECTION_NAME=marketing_knowledge
RAG_TOP_K=3

# === Multi-Agent設定（ノートPC: 軽量化版）
MULTI_AGENT_ENABLED=false
AGENT_TEMPERATURE=0.6
AGENT_MAX_ITERATIONS=4

# === パフォーマンス設定（ノートPC向け最適化）
SQLITE_BUSY_TIMEOUT_MS=60000
URL_PROCESSING_STALE_MINUTES=60
URL_RETRY_DELAY_MINUTES=20

# === ワーカー設定（ノートPC向け軽量化）
WORKER_INTERVAL_SECONDS=600
TARGET_SITE_MAX_PAGES=5
URL_BATCH_SIZE=2
URL_ANALYSIS_TIMEOUT=60
ALLOWED_TARGET_HOSTS=

# === Playwright / Lighthouse 設定（ノートPC向け軽量化）
USE_PLAYWRIGHT=true
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_MAX_PAGES=5
USE_LIGHTHOUSE=true
