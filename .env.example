# === Ollama設定（無料AIをガッツリ強化）
OLLAMA_ENABLED=true
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=300
OLLAMA_NUM_PREDICT=2000
OLLAMA_TEMPERATURE=0.7          # ← 新規追加：創造性と論理のバランス調整
OLLAMA_TOP_P=0.95               # ← 新規追加：多様な出力制御（高品質化）
OLLAMA_SEED=42                  # ← 新規追加：再現性を確保したい時に使用

# === 深掘り分析設定（さらに賢く長文対応）
DEEP_ANALYSIS_ENABLED=true
DEEP_ANALYSIS_NUM_PREDICT=3000

# === AI高度分析機能フラグ（全て有効推奨）
STRATEGIC_LP_ANALYSIS_ENABLED=true
FORECASTING_ENABLED=true
IMPACT_ANALYSIS_ENABLED=true

# === Vision AI設定（画像・LPデザイン分析）← 最強追加推奨
VISION_ANALYSIS_ENABLED=true          # ← 新規追加
OLLAMA_VISION_MODEL=llava:13b         # ← 新規追加（または llava:34b）
VISION_ANALYSIS_TIMEOUT=180           # ← 新規追加
VISION_PROMPT_FILE=prompts/vision_lp_analysis.md  # ← 新規追加

# === RAG設定（自社過去レポート・業界知識をAIに記憶させる）
RAG_ENABLED=true                      # ← 新規追加
CHROMA_PERSIST_DIRECTORY=./data/chroma  # ← 新規追加
RAG_COLLECTION_NAME=marketing_knowledge # ← 新規追加
RAG_TOP_K=5                           # ← 新規追加：類似ドキュメント取得数

# === Multi-Agent設定（自動戦略立案エージェント化）
MULTI_AGENT_ENABLED=true              # ← 新規追加
AGENT_TEMPERATURE=0.6                 # ← 新規追加
AGENT_MAX_ITERATIONS=8                # ← 新規追加：エージェントの思考回数上限

# === パフォーマンス設定（重いAIモデル対応で調整済み）
SQLITE_BUSY_TIMEOUT_MS=60000
URL_PROCESSING_STALE_MINUTES=60
URL_RETRY_DELAY_MINUTES=20

# === ワーカー設定
WORKER_INTERVAL_SECONDS=300
TARGET_SITE_MAX_PAGES=12              # ← 少し増やして深く分析
URL_BATCH_SIZE=3
URL_ANALYSIS_TIMEOUT=60
ALLOWED_TARGET_HOSTS=

# === Playwright / Lighthouse 設定
USE_PLAYWRIGHT=true
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_MAX_PAGES=12               # ← 少し増やして深く分析
USE_LIGHTHOUSE=true